# CO4 - MINIMAX
# =====================================================

class Minimax:

    def minimax(self, depth, node_index,
                maximizing_player, values):

        if depth == 0:
            return values[node_index]

        if maximizing_player:

            return max(
                self.minimax(
                    depth - 1,
                    node_index * 2,
                    False,
                    values
                ),

                self.minimax(
                    depth - 1,
                    node_index * 2 + 1,
                    False,
                    values
                )
            )

        else:

            return min(
                self.minimax(
                    depth - 1,
                    node_index * 2,
                    True,
                    values
                ),

                self.minimax(
                    depth - 1,
                    node_index * 2 + 1,
                    True,
                    values
                )
            )


values = [3, 5, 6, 9, 1, 2, 0, -1]

solver = Minimax()

result = solver.minimax(
    3,
    0,
    True,
    values
)

print("Optimal Utility =", result)
